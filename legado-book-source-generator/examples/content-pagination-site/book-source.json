[{
  "bookSourceUrl": "https://pagination-example.com",
  "bookSourceName": "正文分页样例",
  "searchUrl": "https://pagination-example.com/search?q={{key}}",
  "ruleSearch": {
    "bookList": ".book-list .book-item",
    "name": ".book-title",
    "bookUrl": "a@href"
  },
  "ruleBookInfo": {
    "name": ".book-title",
    "author": ".book-author",
    "tocUrl": ".toc-link@href"
  },
  "ruleToc": {
    "chapterList": ".chapter-list a",
    "chapterName": "text",
    "chapterUrl": "@href"
  },
  "ruleContent": {
    "content": "#content@html",
    "nextContentUrl": "a.next-page@href@js:if(!result){[]}else{var cur=String(baseUrl||'');var next=result;var c=cur.match(/\\/(\\d+)_(\\d+)\\.html/);var n=next.match(/\\/(\\d+)_(\\d+)\\.html/);c&&n&&c[1]===n[1]?[next]:[]}"
  }
}]