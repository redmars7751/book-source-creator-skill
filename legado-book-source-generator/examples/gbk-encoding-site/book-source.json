[{
  "bookSourceUrl": "https://gbk-example.com",
  "bookSourceName": "GBK编码样例",
  "searchUrl": "https://gbk-example.com/search?q={{key}},{\"charset\":\"gbk\"}",
  "ruleSearch": {
    "bookList": ".book-list li",
    "name": ".book-title@text",
    "bookUrl": "a@href"
  },
  "ruleBookInfo": {
    "name": "h1@text",
    "author": ".author@text",
    "tocUrl": ".toc-link@href,{\"charset\":\"gbk\"}"
  },
  "ruleToc": {
    "chapterList": "#list dd a",
    "chapterName": "text",
    "chapterUrl": "@href,{\"charset\":\"gbk\"}"
  },
  "ruleContent": {
    "content": "#content@html,{\"charset\":\"gbk\"}"
  }
}]